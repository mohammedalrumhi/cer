{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Backend",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run Frontend",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev",
				"--",
				"--host",
				"0.0.0.0"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run Backend",
			"type": "shell",
			"command": "cd backend && npm run dev",
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run Frontend",
			"type": "shell",
			"command": "cd frontend && npm run dev -- --host 0.0.0.0",
			"isBackground": true,
			"group": "build"
		}
	]
}